# Copy to ".env" in the project root and fill real values.
# Do NOT commit ".env". This file is safe to commit as a template.

# =========================
# Core API keys
# =========================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxx

# Optional search integration (if used by your flows)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxx

# =========================
# LLM (CrewAI / ChatOpenAI)
# =========================
# Default in code is gpt-5 if this key is omitted.
OPENAI_MODEL=gpt-5
# Example alternatives (based on your OpenAI access):
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4.1
# OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.0

# =========================
# Gemini STT
# =========================
GEMINI_MODEL_NAME=gemini-2.5-flash
FFMPEG_BIN=ffmpeg
SAMPLE_RATE=16000
STT_VAD_AGGRESSIVENESS=3
VAD_FRAME_MS=30
VAD_VOICED_RATIO_MIN=0.65
STT_PARTIAL_MIN_INTERVAL_MS=600
STT_SEGMENT_SILENCE_MS=1200
EMIT_PARTIALS=false

# Optional STT reliability knobs
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-1.5-flash
# GEMINI_MAX_ATTEMPTS=6
# GEMINI_RETRY_BASE_DELAY=0.6
# GEMINI_RETRY_MAX_DELAY=8.0
# STT_USE_WHISPER_FALLBACK=true
# WHISPER_MODEL=small

# =========================
# Database
# =========================
# If omitted, app defaults to SQLite: sqlite:///app.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/early_cancer_db
# Shorthand also accepted by app: postgres://user:pass@host:5432/db

# Optional one-time bootstrap admin (remove after first login)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.org
# BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately

# Used only by scripts/migrate_from_sqlite.py
# SQLITE_SOURCE=./app.db

# Flask (set in production)
# SECRET_KEY=replace-with-a-long-random-secret
