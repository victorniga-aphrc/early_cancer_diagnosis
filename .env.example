# Copy to ".env" in the project root (never commit real secrets).
# python-dotenv loads .env when you start the app (app.py).

# --- Database (optional) ---
# Omit to use default SQLite: sqlite:///app.db
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/early_cancer_db
# Shorthand also works: postgres://...

# --- One-time first admin (optional; remove after first login) ---
# BOOTSTRAP_ADMIN_EMAIL=admin@example.org
# BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately

# --- SQLite → Postgres migration (only when running scripts/migrate_from_sqlite.py) ---
# SQLITE_SOURCE=./app.db

# Flask (production: set a long random string)
# SECRET_KEY=

# Add API keys and other secrets as required by config.py, CrewAI, STT, etc.
